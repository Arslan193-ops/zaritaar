generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_URL")
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  password  String?
  name      String?
  roleId    String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  orders    Order[]
  sessions  Session[]
  role      Role?     @relation(fields: [roleId], references: [id])
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  permissions String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  users       User[]
}

model Session {
  id        String   @id
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Category {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  imageUrl    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]
}

model Product {
  id                String           @id @default(cuid())
  title             String
  slug              String           @unique @default(cuid())
  description       String
  basePrice         Float
  discountedPrice   Float?
  costPrice         Float?
  sku               String?
  stock             Int              @default(0)
  status            String           @default("DRAFT")
  imageUrl          String?
  sizeChart         String?
  attributes        String?
  isFeatured        Boolean          @default(false)
  showSizeSelector  Boolean          @default(false)
  showColorSelector Boolean          @default(false)
  freeShipping      Boolean          @default(false)
  tags              String?
  categoryId        String?
  metaTitle         String?
  metaDescription   String?
  keywords          String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  category          Category?        @relation(fields: [categoryId], references: [id])
  images            ProductImage[]
  variants          ProductVariant[]
}

model ProductImage {
  id        String   @id @default(cuid())
  url       String
  productId String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductVariant {
  id              String      @id @default(cuid())
  productId       String
  attributes      String?
  sku             String?     @unique
  price           Float?
  stock           Int         @default(0)
  imageUrl        String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  discountedPrice Float?
  orderItems      OrderItem[]
  product         Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Order {
  id             String      @id @default(cuid())
  userId         String?
  customerName   String
  customerEmail  String
  customerPhone  String?
  shippingStreet String?
  shippingCity   String?
  shippingState  String?
  totalAmount    Float
  status         String      @default("PENDING")
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  user           User?       @relation(fields: [userId], references: [id])
  items          OrderItem[]
}

model OrderItem {
  id        String         @id @default(cuid())
  orderId   String
  variantId String
  quantity  Int            @default(1)
  price     Float
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  order     Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model StoreSettings {
  id                         String   @id @default("global")
  storeName                  String   @default("My Store")
  desktopHeroImage           String?
  mobileHeroImage            String?
  heroHeadline               String?
  showHeroHeadline           Boolean  @default(true)
  heroButtonText             String?
  heroButtonLink             String?
  showHeroButton             Boolean  @default(true)
  featureImage1              String?
  featureImage2              String?
  featureImage3              String?
  whatsappNumber             String?
  logoUrl                    String?
  logoDarkUrl                String?
  heroSliderImages           String?  @default("[]")
  announcementsText          String?  @default("[\"Get an extra 5% off on your first order using code 'IMNEW' !\"]")
  enableScrollingAnnouncements Boolean @default(false)
  heroBadge                  String?  @default("PREMIUM COLLECTION 2024")
  updatedAt                  DateTime @updatedAt
  facebookPixelId            String?
  tiktokPixelId              String?
}

model ShippingMethod {
  id         String   @id @default(cuid())
  name       String
  duration   String?
  price      Float
  isFree     Boolean  @default(false)
  orderIndex Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
